#!/bin/bash

set -e

PIAPPS_DIR="$HOME/pi-apps"
APPS_DIR="$PIAPPS_DIR/apps"
BIN_DIR="/usr/local/bin"

mkdir -p "$APPS_DIR"

function error {
  echo -e "\e[91mERROR: $1\e[0m"
  exit 1
}

function status {
  echo -e "\e[96m$1\e[0m"
}

function success {
  echo -e "\e[92m$1\e[0m"
}

# -----------------------------
# CPU detection
# -----------------------------
ARCH_RAW=$(uname -m)

case "$ARCH_RAW" in
  x86_64|amd64)
    ARCH=64
  ;;
  aarch64)
    ARCH=64
  ;;
  armv7l|armhf)
    ARCH=32
  ;;
  *)
    ARCH=unknown
  ;;
esac

status "Detected architecture: $ARCH_RAW"

# -----------------------------
# Install packages helper
# -----------------------------
function install_packages {

  sudo apt update

  for pkg in "$@"; do
    status "Installing $pkg"
    sudo apt install -y "$pkg" || error "Failed installing $pkg"
  done
}

# -----------------------------
# Install App
# -----------------------------
function install_app {

  APP="$1"

  [ -z "$APP" ] && error "No app specified"

  if [ ! -d "$APPS_DIR/$APP" ]; then
    error "App not found: $APP"
  fi

  if [ -f "$APPS_DIR/$APP/install" ]; then
    status "Installing $APP"
    bash "$APPS_DIR/$APP/install"
  else
    error "Install script missing for $APP"
  fi

  success "$APP installed"
}

# -----------------------------
# Uninstall App
# -----------------------------
function uninstall_app {

  APP="$1"

  [ -z "$APP" ] && error "No app specified"

  if [ -f "$APPS_DIR/$APP/uninstall" ]; then
    status "Uninstalling $APP"
    bash "$APPS_DIR/$APP/uninstall"
  else
    error "Uninstall script missing for $APP"
  fi

  success "$APP removed"
}

# -----------------------------
# List apps
# -----------------------------
function list_apps {

  echo
  echo "Available apps:"
  echo

  if [ -z "$(ls -A "$APPS_DIR" 2>/dev/null)" ]; then
    echo "No apps installed."
    return
  fi

  for d in "$APPS_DIR"/*; do
    [ -d "$d" ] && basename "$d"
  done

  echo
}

# -----------------------------
# Command handler
# -----------------------------
case "$1" in

install)
  install_app "$2"
;;

uninstall)
  uninstall_app "$2"
;;

list)
  list_apps
;;

*)

echo
echo "Pi-Apps-Amd64"
echo
echo "Commands:"
echo
echo "pi-apps-amd64 install APP"
echo "pi-apps-amd64 uninstall APP"
echo "pi-apps-amd64 list"
echo
;;

esac
