#!/bin/bash

# -----------------------------
# Install Brave Browser (amd64)
# -----------------------------

# Update system
sudo apt update || exit 1
sudo apt install -y apt-transport-https curl gnupg || exit 1

# Add Brave repo and key
sudo curl -fsSLo /usr/share/keyrings/brave-browser-archive-keyring.gpg https://brave-browser-apt-release.s3.brave.com/brave-browser-archive-keyring.gpg
echo "deb [signed-by=/usr/share/keyrings/brave-browser-archive-keyring.gpg arch=amd64] https://brave-browser-apt-release.s3.brave.com/ stable main" | sudo tee /etc/apt/sources.list.d/brave-browser.list

# Update & install
sudo apt update
sudo apt install -y brave-browser

echo "Brave Browser amd64 installation complete!"
