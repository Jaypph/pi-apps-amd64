#!/bin/bash

# -----------------------------
# Install ClamAV + ClamTK (amd64)
# -----------------------------

version=6.18
version2=0.08-2

# Update system & install dependencies
sudo apt update || exit 1
sudo apt install -y clamav wget gdebi-core || exit 1

# Install ClamTK .deb
wget -O /tmp/clamtk_${version}-1_all.deb "https://github.com/dave-theunsub/clamtk/releases/download/v${version}/clamtk_${version}-1_all.deb" || { echo "Failed to download ClamTK"; exit 1; }
sudo gdebi -n /tmp/clamtk_${version}-1_all.deb
rm -f /tmp/clamtk_${version}-1_all.deb

# If Thunar is installed, also install ClamTK Thunar extension
if command -v thunar >/dev/null ; then
    echo "Thunar detected – installing ClamTK Thunar extension..."
    deb_minor_version=${version2/${version2%-*}/}
    wget -O /tmp/thunar-sendto-clamtk_${version2%-*}${deb_minor_version:--1}_all.deb "https://github.com/dave-theunsub/thunar-sendto-clamtk/releases/download/v${version2}/thunar-sendto-clamtk_${version2%-*}${deb_minor_version:--1}_all.deb" || { echo "Failed to download Thunar extension"; exit 1; }
    sudo gdebi -n /tmp/thunar-sendto-clamtk_${version2%-*}${deb_minor_version:--1}_all.deb
    rm -f /tmp/thunar-sendto-clamtk_${version2%-*}${deb_minor_version:--1}_all.deb
fi

echo "ClamAV + ClamTK amd64 installation complete!"
exit 0
