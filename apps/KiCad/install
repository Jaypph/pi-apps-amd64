#!/bin/bash

# -----------------------------
# Install KiCad (amd64)
# -----------------------------

# Update system
sudo apt update || exit 1
sudo apt install -y wget software-properties-common apt-transport-https gnupg || exit 1

# Determine Debian/Ubuntu codename
CODENAME=$(lsb_release -cs)

# Add backports if on Debian Bookworm
if [ "$CODENAME" == "bookworm" ]; then
    echo "Adding Bookworm backports..."
    echo "deb http://deb.debian.org/debian bookworm-backports main contrib non-free non-free-firmware" | sudo tee /etc/apt/sources.list.d/bookworm-backports.list >/dev/null
    sudo apt update
    sudo apt install -y -t bookworm-backports kicad kicad-libraries || { echo "Failed to install KiCad from backports"; exit 1; }
else
    # Use apt or Flatpak for other amd64 systems
    if command -v flatpak >/dev/null; then
        echo "Installing KiCad via Flatpak..."
    else
        sudo apt install -y flatpak || { echo "Failed to install Flatpak"; exit 1; }
    fi
    flatpak install -y flathub org.kicad.KiCad || { echo "Failed to install KiCad via Flatpak"; exit 1; }
fi

echo "KiCad amd64 installation complete!"
