#!/bin/bash

error() { echo -e "\e[91m$1\e[0m" 1>&2; exit 1; }
status() { echo -e "\e[96m$1\e[0m" 1>&2; }
status_green() { echo -e "\e[92m$1\e[0m" 1>&2; }

# Disable any existing swap services
if systemctl is-active --quiet dphys-swapfile.service 2>/dev/null; then
    status "Disabling Raspberry Pi swap service (if present)"
    sudo swapoff -a
    sudo systemctl mask dphys-swapfile.service
fi
if systemctl is-active --quiet mkswap.service 2>/dev/null; then
    status "Disabling generic mkswap service"
    sudo swapoff -a
    sudo systemctl mask mkswap.service
fi

# Ensure zram module loaded
if ! lsmod | grep -q zram; then
    sudo modprobe zram || error "Failed to load zram kernel module"
fi
status_green "ZRAM module loaded"

# Create /usr/bin/zram.sh
sudo tee /usr/bin/zram.sh >/dev/null <<'EOF'
#!/bin/bash
if [ $(id -u) -ne 0 ]; then
    echo "zram.sh must be run as root"; exit 1
fi

# Disable old zram devices
for d in $(ls /dev/zram* 2>/dev/null); do
    swapoff "$d" 2>/dev/null
    echo "$d" | sed 's+/dev/++' > /sys/class/zram-control/hot_remove 2>/dev/null || true
done

# Create 4 zram swap devices
for i in {1..4}; do
    devnum=$(cat /sys/class/zram-control/hot_add)
    totalmem=$(awk '/MemTotal/ {print $2*1024}' /proc/meminfo)
    echo lz4 > /sys/block/zram$devnum/comp_algorithm
    echo $totalmem > /sys/block/zram$devnum/disksize
    mkswap /dev/zram$devnum
    swapon /dev/zram$devnum -d -p 1
done

# Optional /zram storage (4x RAM)
storage_drive=$(cat /sys/class/zram-control/hot_add)
echo lz4 > /sys/block/zram$storage_drive/comp_algorithm
echo $((totalmem*4)) > /sys/block/zram$storage_drive/disksize
mkfs.ext4 -F /dev/zram$storage_drive
mkdir -p /zram
mount /dev/zram$storage_drive /zram
chmod -R 777 /zram
EOF

sudo chmod +x /usr/bin/zram.sh

# Setup systemd services
sudo tee /etc/systemd/system/zram-swap.service >/dev/null <<EOF
[Unit]
Description=Configures ZRAM swap devices
After=local-fs.target

[Service]
Type=oneshot
ExecStart=/usr/bin/zram.sh
ExecStop=/usr/bin/zram.sh stop
RemainAfterExit=yes

[Install]
WantedBy=multi-user.target
EOF

sudo tee /etc/systemd/system/zram-flush.timer >/dev/null <<EOF
[Unit]
Description=Flush ZRAM every 5 min

[Timer]
OnBootSec=5min
OnUnitActiveSec=5min

[Install]
WantedBy=multi-user.target
EOF

sudo systemctl daemon-reload
sudo systemctl enable --now zram-swap.service
sudo systemctl enable --now zram-flush.timer

status "Running ZRAM setup..."
sudo /usr/bin/zram.sh || error "ZRAM setup failed"

status_green "ZRAM amd64 setup complete!"
